NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=true
ADMIN_API_KEY=

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/stockpromo?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stock-promo-bot/1.0
REDDIT_RAPIDAPI_KEY=
REDDIT_RAPIDAPI_HOST=
REDDIT_RAPIDAPI_BASE_URL=https://example-reddit-api.p.rapidapi.com
REDDIT_RAPIDAPI_PATH_TEMPLATE=/reddit/r/{subreddit}/hot
REDDIT_RAPIDAPI_METHOD=GET
REDDIT_RAPIDAPI_LIMIT_PARAM=limit
REDDIT_RAPIDAPI_TIME_PARAM=time
REDDIT_RAPIDAPI_TIME_VALUE=day
REDDIT_SYNC_TREND_WINDOW=true
REDDIT_RAPIDAPI_ITEMS_PATH=data.children
REDDIT_RAPIDAPI_ITEM_DATA_PATH=data
REDDIT_SUBREDDITS=stocks,investing,wallstreetbets,pennystocks,CryptoCurrency
REDDIT_FETCH_LIMIT=25
REDDIT_MOCK_ENABLED=false
REDDIT_MOCK_DATA_JSON=[]

WATCHLIST_SYMBOLS=AAPL,TSLA,NVDA,MSFT,BTC,ETH,SOL
# Must be a valid RFC3986 URI. If you need a template, use %7Bsymbol%7D (encoded "{symbol}")
STOCKTWITS_SIGNAL_API_URL=
STOCKTWITS_SIGNAL_MOCK_ENABLED=false
STOCKTWITS_SIGNAL_MOCK_DATA_JSON=[]
NEWS_SENTIMENT_API_URL=https://example.com/news
NEWS_SENTIMENT_API_KEY=
NEWS_MOCK_ENABLED=false
NEWS_MOCK_DATA_JSON=[]

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ACCOUNTS_JSON=[]
TELEGRAM_DEFAULT_CHAT_IDS=
TELEGRAM_DISCOVERY_SEEDS=

STOCKTWITS_LOGIN_URL=https://stocktwits.com/signin
STOCKTWITS_POST_URL=https://stocktwits.com
STOCKTWITS_ACCOUNTS_JSON=[]
STOCKTWITS_HEADLESS=true
STOCKTWITS_USER_DATA_DIR=
STOCKTWITS_MANUAL_LOGIN_TIMEOUT_MS=120000
STOCKTWITS_BROWSER_BINARY=

PIPELINE_CRON=*/5 * * * *
TREND_WINDOWS_HOURS=1,6,24
TREND_MIN_WEIGHTED_MENTIONS=1
TREND_MIN_UNIQUE_EVENTS=1
TREND_MIN_SCORE=0
TOP_TRENDS_LIMIT=10
AUTO_APPROVAL_MIN_SCORE=0.75
CONTENT_PROMPT_VERSION=phase1-v1
CONTENT_DISCLOSURE_VERSION=v1
PUBLISH_COOLDOWN_MINUTES=90
PUBLISH_MAX_RETRIES=3
PUBLISH_RETRY_DELAY_SECONDS=30
PUBLISH_DEAD_LETTER_ENABLED=true
PUBLISH_REPLAY_BATCH_SIZE=200
PHASE2_PER_ACCOUNT_QUOTA=4
PHASE2_GLOBAL_QUOTA=12
PHASE2_QUIET_HOURS_START=
PHASE2_QUIET_HOURS_END=
PHASE2_MIN_DELAY_MINUTES=10
PHASE2_MAX_DELAY_MINUTES=45
PHASE2_ADAPTIVE_COOLDOWN_MINUTES=30
PHASE2_DUPLICATE_SIMILARITY_THRESHOLD=0.82
SOURCE_CONNECTOR_WEIGHTS_JSON={"REDDIT":1,"STOCKTWITS_SIGNAL":0.9,"NEWS_API":0.8}
SOURCE_CONNECTOR_PRIORITIES_JSON={"REDDIT":100,"STOCKTWITS_SIGNAL":90,"NEWS_API":80}
HTTP_REQUEST_TIMEOUT_MS=10000
HTTP_MAX_RETRIES=2
RETENTION_ENABLED=true
RETENTION_CRON=15 2 * * *
RETENTION_SOURCE_EVENTS_DAYS=30
RETENTION_AUDIT_EVENTS_DAYS=365
RETENTION_PUBLISH_ATTEMPTS_DAYS=90
RETENTION_DLQ_DAYS=180
